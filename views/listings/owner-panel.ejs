<% layout("/layouts/boilerplate") %>

<div class="container mt-4 mb-5">
  <h2 class="mb-3">Owner Panel</h2>
  <p class="text-muted">
    View reviews and bookings for listings you own.
  </p>

  <% if (!listings || listings.length === 0) { %>
    <div class="alert alert-info">You have no listings yet.</div>
  <% } else { %>
    <% listings.forEach(listing => { %>
      <div class="card mb-4">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <h4 class="card-title mb-1"><%= listing.title %></h4>
              <p class="card-text text-muted mb-2"><%= listing.location %>, <%= listing.country %></p>
            </div>
            <a class="btn btn-sm btn-outline-dark" href="/listings/<%= listing._id %>">View Listing</a>
          </div>

          <hr />

          <h5 class="mb-3">Bookings</h5>
          <% const bookingItems = bookingsByListing[listing._id] || []; %>
          <% if (bookingItems.length === 0) { %>
            <p class="text-muted mb-3">No bookings yet.</p>
          <% } else { %>
            <div class="table-responsive mb-4">
              <table class="table table-sm align-middle">
                <thead>
                  <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>From</th>
                    <th>To</th>
                    <th>Booked On</th>
                  </tr>
                </thead>
                <tbody>
                  <% bookingItems.forEach(item => { %>
                    <tr>
                      <td>@<%= item.user.username %></td>
                      <td><%= item.user.email %></td>
                      <td><%= item.booking.fromDate.toISOString().slice(0, 10) %></td>
                      <td><%= item.booking.toDate.toISOString().slice(0, 10) %></td>
                      <td><%= item.booking.createdAt.toISOString().slice(0, 10) %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>

          <h5 class="mb-3">Reviews</h5>
          <% if (!listing.reviews || listing.reviews.length === 0) { %>
            <p class="text-muted">No reviews yet.</p>
          <% } else { %>
            <div class="row">
              <% listing.reviews.forEach(review => { %>
                <div class="col-md-6 mb-3">
                  <div class="card h-100">
                    <div class="card-body">
                      <h6 class="card-title mb-1">@<%= review.author.username %></h6>
                      <p class="starability-result mb-2" data-rating="<%= review.rating %>"></p>
                      <p class="card-text"><%= review.comment %></p>
                      <p class="text-muted mb-0">
                        <%= review.createdAt.toISOString().slice(0, 10) %>
                      </p>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>
